<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- VEHICLE TYPES DEFINITION -->
    <!-- Defines the physical and performance characteristics of different vehicle classes -->
    
    <!-- Highly prioritized emergency vehicle (Red color) -->
    <vType id="emergency_vehicle" length="6.0" maxSpeed="20.0" accel="4.0" decel="6.0" sigma="0.2" vClass="emergency" color="red"/>

    <!-- VEHICLE TYPE DISTRIBUTIONS -->
    <!-- Defines physical characteristics and probabilities in one block -->
    <vTypeDistribution id="standard_traffic">
        <vType id="normal_car" length="5.0" maxSpeed="13.89" accel="2.6" decel="4.5" sigma="0.5" vClass="passenger" probability="0.8"/>
        <vType id="bus" length="12.0" maxSpeed="10.0" accel="1.2" decel="4.0" sigma="0.5" vClass="bus" probability="0.1"/>
        <vType id="motorcycle" length="2.0" maxSpeed="15.0" accel="5.0" decel="7.0" sigma="0.2" vClass="motorcycle" probability="0.1"/>
    </vTypeDistribution>

    <!-- ROUTE DEFINITIONS -->
    <!-- Defines the paths through the network edges -->

    <!-- North-South approach -->
    <route id="n_s" edges="north_to_center center_to_south"/>
    <route id="n_e" edges="north_to_center center_to_east"/>
    <route id="n_w" edges="north_to_center center_to_west"/>

    <!-- South-North approach -->
    <route id="s_n" edges="south_to_center center_to_north"/>
    <route id="s_e" edges="south_to_center center_to_east"/>
    <route id="s_w" edges="south_to_center center_to_west"/>

    <!-- East-West approach -->
    <route id="e_w" edges="east_to_center center_to_west"/>
    <route id="e_n" edges="east_to_center center_to_north"/>
    <route id="e_s" edges="east_to_center center_to_south"/>

    <!-- West-East approach -->
    <route id="w_e" edges="west_to_center center_to_east"/>
    <route id="w_n" edges="west_to_center center_to_north"/>
    <route id="w_s" edges="west_to_center center_to_south"/>

    <!-- TRAFFIC FLOWS -->
    <!-- Defines the demand for vehicles over time (3600 seconds) -->
    <!-- Corresponds to High (NS: 800 vph) and Medium (EW: 500 vph) rates -->
    <!-- Note: Random turning (30%) is handled by splitting flows 70% straight, 15% left, 15% right -->

    <!-- North-South High Traffic (800 vph total per approach) -->
    <flow id="car_ns_" type="standard_traffic" begin="0" end="3600" vehsPerHour="560" route="n_s"/>
    <flow id="car_ne_" type="standard_traffic" begin="0" end="3600" vehsPerHour="120" route="n_e"/>
    <flow id="car_nw_" type="standard_traffic" begin="0" end="3600" vehsPerHour="120" route="n_w"/>

    <flow id="car_sn_" type="standard_traffic" begin="0" end="3600" vehsPerHour="560" route="s_n"/>
    <flow id="car_se_" type="standard_traffic" begin="0" end="3600" vehsPerHour="120" route="s_e"/>
    <flow id="car_sw_" type="standard_traffic" begin="0" end="3600" vehsPerHour="120" route="s_w"/>

    <!-- East-West Medium Traffic (500 vph total per approach) -->
    <flow id="car_ew_" type="standard_traffic" begin="0" end="3600" vehsPerHour="350" route="e_w"/>
    <flow id="car_en_" type="standard_traffic" begin="0" end="3600" vehsPerHour="75" route="e_n"/>
    <flow id="car_es_" type="standard_traffic" begin="0" end="3600" vehsPerHour="75" route="e_s"/>

    <flow id="car_we_" type="standard_traffic" begin="0" end="3600" vehsPerHour="350" route="w_e"/>
    <flow id="car_wn_" type="standard_traffic" begin="0" end="3600" vehsPerHour="75" route="w_n"/>
    <flow id="car_ws_" type="standard_traffic" begin="0" end="3600" vehsPerHour="75" route="w_s"/>

    <!-- EMERGENCY VEHICLE SCENARIOS -->
    <!-- Specific high-priority vehicles injected at T=1800 -->
    
    <!-- Emergency vehicle 1: South to North -->
    <vehicle id="emergency_001" type="emergency_vehicle" depart="1800" departLane="best">
        <route edges="south_to_center center_to_north"/>
    </vehicle>

    <!-- Emergency vehicle 2: West to East -->
    <vehicle id="emergency_002" type="emergency_vehicle" depart="1800" departLane="best">
        <route edges="west_to_center center_to_east"/>
    </vehicle>

</routes>
